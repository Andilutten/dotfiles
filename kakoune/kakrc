map global normal <space> , -docstring 'leader'

# User mode (FILES)
declare-user-mode files
map global user f %{: enter-user-mode files<ret>} -docstring "Files"
define-command -docstring "Find files using fzf through tmux" tmux-find-file %{
	edit %sh{
    		TMPFILE=$(mktemp)

    		if git status > /dev/null 2>&1; then
        		git ls-files > $TMPFILE
		else
        		find . -type f > $TMPFILE
        	fi

		fzf-tmux --prompt="Find file: " -p < $TMPFILE
	}
}
map global files f %{: tmux-find-file<ret>} -docstring "Find file"
map global files k %{: edit ~/.config/kak/kakrc<ret>} -docstring "Open kakrc"

# OPTIONS
set-option -add global ui_options \
	ncurses_assistant=none \
	ncurses_status_on_top=true

# THEMING
colorscheme desertex
set-face global BufferPadding black,default


## LSP stuff
evaluate-commands %sh{kak-lsp --kakoune -s $kak_session}
hook global WinSetOption filetype=(go|javascript|typescript) %{
	lsp-enable-window
	lsp-auto-hover-enable
}

map global user l %{: enter-user-mode lsp<ret>} -docstring "LSP mode"
